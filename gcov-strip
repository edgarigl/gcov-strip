import argparse
import linecache
import os
import struct
import sys
from collections import defaultdict
from typing import DefaultDict, Dict, Iterable, List, Optional, Set, Tuple


GCOV_TAG_FUNCTION = 0x01000000
GCOV_TAG_LINES = 0x01450000
GCOV_HEADER_SIZE = 16


def parse_config_entry(line: str) -> Tuple[str, str]:
    """Parse one config line into `(object_path, function)`."""
    # Config entries are always `object:function`.
    if ":" not in line:
        raise ValueError(f"invalid config entry {line!r}: expected object:function")
    obj_path, function = line.rsplit(":", 1)
    if not obj_path or not function:
        raise ValueError(f"invalid config entry {line!r}: expected object:function")
    return os.path.normpath(obj_path), function


def load_function_list(
    path: str,
) -> DefaultDict[str, Set[str]]:
    """Load one removal config file."""
    # Read one object-qualified config file of removals.
    functions_by_object: DefaultDict[str, Set[str]] = defaultdict(set)
    with open(path, "r", encoding="utf-8") as handle:
        for line in handle:
            stripped = line.strip()

            # Skip empty or commented lines
            if not stripped or stripped.startswith("#"):
                continue

            obj_path, function = parse_config_entry(stripped)
            functions_by_object[obj_path].add(function)
    return functions_by_object


def gcno_object_keys(path: str) -> Set[str]:
    """Return object-path keys that may correspond to one gcno file."""
    # Derive the object names that may correspond to this gcno file. Relative
    # paths are preferred so generated configs remain stable across workspaces.
    abs_gcno = os.path.abspath(path)
    rel_gcno = os.path.relpath(abs_gcno, os.getcwd())
    keys = set()
    for gcno_path in (abs_gcno, rel_gcno, os.path.basename(rel_gcno)):
        if gcno_path.endswith(".gcno"):
            # Try a few path spellings because linker logs and generated config
            # files may record the same object as an absolute path, a cwd-
            # relative path, or just a basename.
            keys.add(os.path.normpath(gcno_path[:-5] + ".o"))
    return keys


def removal_set_for_gcno(
    path: str,
    functions_by_object: DefaultDict[str, Set[str]],
) -> Set[str]:
    """Build the removal set that applies to one gcno file."""
    # Only object-qualified removals are active.
    matched = set()
    for key in gcno_object_keys(path):
        matched.update(functions_by_object.get(key, set()))
    return matched


def record_start_offset(data: bytes) -> int:
    """Return the byte offset where per-function gcno records begin."""
    # Skip the gcno file header and the compile-unit record that precedes the
    # per-function records we want to filter.
    offset = GCOV_HEADER_SIZE
    if offset + 4 > len(data):
        raise ValueError("missing unit record")
    (length,) = struct.unpack_from("<I", data, offset)
    offset += 4
    if offset + length > len(data):
        raise ValueError("truncated unit record")
    offset += length
    if offset + 4 > len(data):
        raise ValueError("truncated unit record checksum")
    offset += 4
    return offset


def iter_gcno_records(data: bytes, start_offset: int) -> Iterable[Tuple[int, bytes]]:
    """Yield `(tag, payload)` pairs for gcno records starting at `start_offset`."""
    # Yield each gcno record as `(tag, payload)` from the first function record
    # onward. The payload length is stored in the record header.
    offset = start_offset
    while offset < len(data):
        if offset + 8 > len(data):
            raise ValueError("truncated record header")
        tag, length = struct.unpack_from("<II", data, offset)
        offset += 8
        if tag == 0:
            break
        if offset + length > len(data):
            raise ValueError("truncated record payload")
        payload = data[offset : offset + length]
        offset += length
        yield tag, payload


def read_gcov_string(payload: bytes, offset: int) -> Tuple[Optional[str], int]:
    """Decode one gcov string field and return `(value, new_offset)`."""
    # Decode a gcov string field and return the updated byte offset so callers
    # can continue parsing the surrounding record.
    if offset + 4 > len(payload):
        return None, offset
    (length,) = struct.unpack_from("<I", payload, offset)
    offset += 4
    if length == 0:
        return "", offset
    if offset + length > len(payload):
        return None, offset
    raw = payload[offset : offset + length]
    offset += length
    nul_index = raw.find(b"\x00")
    if nul_index != -1:
        raw = raw[:nul_index]
    return raw.decode("utf-8", errors="replace"), offset


def parse_function_name(payload: bytes) -> Optional[str]:
    """Extract a function name from a `GCOV_TAG_FUNCTION` payload."""
    # Extract the function name from a `GCOV_TAG_FUNCTION` payload. The first
    # 12 bytes hold numeric metadata before the gcov string.
    if len(payload) < 12:
        return None
    offset = 12
    name, offset = read_gcov_string(payload, offset)
    if name is None:
        return None
    return name


def parse_line_record(payload: bytes) -> Dict[str, Set[int]]:
    """Parse one `GCOV_TAG_LINES` payload into `file -> line numbers`."""
    # Parse a `GCOV_TAG_LINES` payload into `file -> line numbers` so `--list-lines`
    # can report which source lines were removed along with a function.
    if len(payload) < 4:
        return {}
    offset = 0
    offset += 4
    current_file: Optional[str] = None
    lines_by_file: Dict[str, Set[int]] = {}

    while offset + 4 <= len(payload):
        (line_number,) = struct.unpack_from("<I", payload, offset)
        offset += 4

        if line_number == 0:
            # In line records, `0` switches the current source file or ends the
            # record when followed by an empty string.
            filename, offset = read_gcov_string(payload, offset)
            if filename is None:
                break
            if filename == "":
                break
            current_file = filename
            continue

        if not current_file:
            continue

        lines_by_file.setdefault(current_file, set()).add(line_number)

    return lines_by_file


def rebuild_gcno(
    data: bytes,
    remove_functions: Set[str],
    list_lines: bool = False,
) -> Tuple[bytes, int, List[str], List[Tuple[str, Dict[str, Set[int]]]]]:
    """Rewrite one gcno file in memory with selected functions removed."""
    # Rebuild a gcno file in memory, omitting any function record whose name is
    # in `remove_functions` and any trailing records that belong to that
    # function. Optionally collect line info for removed functions.
    if len(data) < GCOV_HEADER_SIZE:
        raise ValueError("missing gcno header")

    prefix_end = record_start_offset(data)
    output = bytearray()
    output.extend(data[:prefix_end])

    state = {
        "skip_current": False,
        "removed": 0,
        "removed_names": [],
        "removed_lines": [],
        "current_removed_lines": None,
    }

    for tag, payload in iter_gcno_records(data, prefix_end):
        if handle_function_record(tag, payload, remove_functions, list_lines, state):
            continue

        if state["skip_current"] and list_lines and tag == GCOV_TAG_LINES:
            # Line records arrive after the owning function record, so collect
            # them before dropping the bytes from the rebuilt output.
            if state["current_removed_lines"] is not None:
                parsed = parse_line_record(payload)
                for filename, lines in parsed.items():
                    state["current_removed_lines"].setdefault(filename, set()).update(lines)
            continue

        if state["skip_current"]:
            # Skip all record types until the next function record starts.
            continue

        output.extend(struct.pack("<II", tag, len(payload)))
        output.extend(payload)

    return (
        bytes(output),
        state["removed"],
        state["removed_names"],
        state["removed_lines"],
    )


def handle_function_record(
    tag: int,
    payload: bytes,
    remove_functions: Set[str],
    list_lines: bool,
    state: Dict[str, object],
) -> bool:
    """Update removal state when a new function record starts."""
    if tag != GCOV_TAG_FUNCTION:
        return False

    name = parse_function_name(payload)
    state["skip_current"] = name in remove_functions if name else False
    if not state["skip_current"]:
        state["current_removed_lines"] = None
        return False

    state["removed"] = int(state["removed"]) + 1

    if name:
        state["removed_names"].append(name)

    if list_lines:
        label = name if name else "<unknown>"
        state["current_removed_lines"] = {}
        state["removed_lines"].append((label, state["current_removed_lines"]))
    return True


def find_gcno_files(root: str) -> Iterable[str]:
    """Yield gcno files recursively under `root`."""
    # Discover gcno files recursively under the chosen root.
    for base, _, files in os.walk(root):
        for filename in files:
            if filename.endswith(".gcno"):
                yield os.path.join(base, filename)


def process_file(
    path: str, remove_functions: Set[str], list_lines: bool = False
) -> Tuple[bool, int, List[str], List[Tuple[str, Dict[str, Set[int]]]]]:
    """Rewrite one gcno file in place if any selected functions are removed."""
    # Rewrite a single gcno file in place if any records are removed.
    with open(path, "rb") as handle:
        data = handle.read()

    updated, removed, removed_names, removed_lines = rebuild_gcno(
        data, remove_functions, list_lines=list_lines
    )
    if updated == data:
        return False, removed, removed_names, removed_lines

    with open(path, "wb") as handle:
        handle.write(updated)
    return True, removed, removed_names, removed_lines


def resolve_source_path(gcno_path: str, source_name: str) -> str:
    """Best-effort source path resolution for gcno line-table filenames."""
    # Best-effort resolution for file names stored in gcno line tables. They
    # may be absolute, relative to the object directory, or relative to cwd.
    if os.path.isabs(source_name):
        return source_name
    base_dir = os.path.dirname(gcno_path)
    candidate = os.path.join(base_dir, source_name)
    if os.path.exists(candidate):
        return candidate
    candidate = os.path.join(os.getcwd(), source_name)
    if os.path.exists(candidate):
        return candidate
    return os.path.join(base_dir, source_name)


def print_removed_lines(
    gcno_path: str, removed_lines: List[Tuple[str, Dict[str, Set[int]]]]
) -> None:
    """Print the source lines associated with removed functions."""
    # Print the source lines associated with removed functions to make the
    # effect of stripping easier to inspect during local runs.
    for function_name, lines_by_file in removed_lines:
        if not lines_by_file:
            continue

        print(f"removed lines for {function_name} in {gcno_path}:")
        for filename in sorted(lines_by_file):
            source_path = resolve_source_path(gcno_path, filename)
            for line_number in sorted(lines_by_file[filename]):
                source_line = linecache.getline(source_path, line_number).rstrip("\n")
                if source_line:
                    print(f"{filename}:{line_number}: {source_line}")
                else:
                    print(f"{filename}:{line_number}")


def parse_args(argv: List[str]) -> argparse.Namespace:
    """Parse command-line arguments."""
    # Keep the CLI narrow: object-qualified config files define removals, and
    # flags only control reporting versus in-place rewriting.
    parser = argparse.ArgumentParser(
        description=(
            "Remove selected function records from .gcno files found "
            "recursively under the current directory."
        )
    )
    parser.add_argument(
        "-c",
        "--config",
        action="append",
        required=True,
        help="Path to a text file listing object:function removals."
        " Can be provided multiple times.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Report removals without modifying any files.",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print per-file removal details.",
    )
    parser.add_argument(
        "--list-lines",
        action="store_true",
        help="List source lines associated with removed functions.",
    )
    return parser.parse_args(argv)


def load_removals(
    config_paths: List[str],
) -> DefaultDict[str, Set[str]]:
    """Load all config files into one object-qualified removal map."""
    functions_by_object: DefaultDict[str, Set[str]] = defaultdict(set)
    for path in config_paths:
        object_functions = load_function_list(path)
        for obj_path, names in object_functions.items():
            functions_by_object[obj_path].update(names)
    return functions_by_object


def handle_gcno_file(
    path: str,
    args: argparse.Namespace,
    functions_by_object: DefaultDict[str, Set[str]],
) -> Tuple[int, int]:
    """Process one gcno file and return `(changed_files_delta, removed_count)`."""
    remove_for_file = removal_set_for_gcno(
        path,
        functions_by_object,
    )
    if not remove_for_file:
        # Skip unrelated gcno files entirely; removals are always object-scoped.
        return 0, 0

    if args.dry_run:
        with open(path, "rb") as handle:
            data = handle.read()

        _, removed, removed_names, removed_lines = rebuild_gcno(
            data, remove_for_file, list_lines=args.list_lines
        )
        changed = removed > 0
    else:
        changed, removed, removed_names, removed_lines = process_file(
            path, remove_for_file, list_lines=args.list_lines
        )

    if args.verbose and removed_names:
        for name in removed_names:
            print(f"removed {name} from {path}")

    if args.list_lines and removed_lines:
        print_removed_lines(path, removed_lines)

    return int(changed), removed


def main(argv: List[str]) -> int:
    """Load configs, rewrite matching gcno files, and print a short summary."""
    # Load the removal set once, then apply it to every gcno file beneath the
    # current working directory.
    args = parse_args(argv)
    functions_by_object = load_removals(args.config)
    if not functions_by_object:
        return 0

    changed_files = 0
    total_removed = 0
    for path in find_gcno_files(os.getcwd()):
        try:
            changed, removed = handle_gcno_file(
                path,
                args,
                functions_by_object,
            )
        except ValueError as exc:
            print(f"Skipping {path}: {exc}", file=sys.stderr)
            continue

        if removed:
            total_removed += removed
        if changed:
            changed_files += 1

    print(
        f"Processed {changed_files} file(s); "
        f"removed {total_removed} function record(s)."
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
